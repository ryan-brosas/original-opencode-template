      "name": "ProxyPal",
      "npm": "@ai-sdk/anthropic",
      "options": {
        "apiKey": "proxypal-local",
        "baseURL": "http://127.0.0.1:8317/v1",
        "includeUsage": true
      }
    },
    "opencode-go": {
      "description": "OpenCode Go subscription — $10/mo for open coding models",
      "options": {
        "baseURL": "https://opencode.ai/zen/go/v1"
      },
      "models": {
        "deepseek-v4-flash": {
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "reasoning": true,
          "tool_call": true
        },
        "mimo-v2.5": {
          "limit": {
            "context": 180000,
            "output": 64000
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "reasoning": true,
          "tool_call": true
        },
        "deepseek-v4-pro": {
          "limit": {
            "context": 240000,
            "output": 64000
          },
          "reasoning": true,
          "tool_call": true
        },
        "mimo-v2.5-pro": {
          "limit": {
            "context": 220000,
            "output": 64000
          },
          "modalities": {
            "input": ["text", "image", "audio"],
            "output": ["text"]
          },
          "reasoning": true,
          "tool_call": true
        },
        "qwen3.7-plus": {
          "limit": {
            "context": 300000,
            "output": 64000
          },
          "modalities": {
            "input": ["text", "image", "video"],
            "output": ["text"]
          },
          "reasoning": true,
          "tool_call": true
        },
        "minimax-m3": {
          "limit": {
            "context": 512000,
            "output": 64000
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "reasoning": true,
          "tool_call": true
        }
      }
    },
    "deepseek": {
      "description": "Direct DeepSeek API — deepseek-v4-flash & deepseek-v4-pro 1M native context",
      "models": {
        "deepseek-v4-flash": {
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "reasoning": true,
          "tool_call": true
        },
        "deepseek-v4-pro": {
          "limit": {
            "context": 240000,
            "output": 64000
          },
          "reasoning": true,
          "tool_call": true
        }
      }
    },
    "xiaomi-mimo": {
      "description": "Direct Xiaomi MiMo API — mimo-v2.5 & mimo-v2.5-pro 1M native context",
      "models": {
        "mimo-v2.5": {
          "limit": {
            "context": 180000,
            "output": 64000
          },
          "modalities": {
