{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "agent": {
    "build": {
      "description": "Primary development agent with full codebase access",
      "model": "opencode/deepseek-v4-flash-free"
    },
    "compaction": {
      "description": "Session summarizer for context continuity across compactions"
    },
    "explore": {
      "description": "Fast codebase search specialist",
      "model": "opencode/deepseek-v4-flash-free"
    },
    "general": {
      "description": "General-purpose subagent for fast, well-defined tasks; delegates complexity quickly",
      "model": "opencode/deepseek-v4-flash-free"
    },
    "plan": {
      "description": "Primary planning agent for architecture and multi-phase execution",
      "model": "opencode/mimo-v2.5-free"
    },
    "review": {
      "description": "Code review, debugging, and security audit specialist",
      "model": "opencode/deepseek-v4-flash-free"
    },
    "scout": {
      "description": "External research specialist for library docs and patterns",
      "model": "opencode/deepseek-v4-flash-free"
    },
    "vision": {
      "description": "Visual content specialist for multimodal analysis and UI/UX guidance",
      "model": "opencode/mimo-v2.5-free"
    }
  },
  "autoupdate": false,
  "compaction": {
    "auto": true,
    "reserved": 16384
  },
  "formatter": {
    "oxfmt": {
      "command": ["npx", "oxfmt", "$FILE"],
      "extensions": [".js", ".jsx", ".ts", ".tsx", ".json", ".jsonc", ".cjs", ".mjs", ".mts"]
    }
  },
  "instructions": [],
  "keybinds": {
    "leader": "ctrl+x",
    "session_child_first": "<leader>down",
    "session_child_cycle": "right",
    "session_child_cycle_reverse": "left",
    "session_parent": "up"
  },
  "mcp": {
    "figma-mcp-go": {
      "command": ["npx", "-y", "@vkhanhqui/figma-mcp-go@latest"],
      "enabled": false,
      "timeout": 120000,
      "type": "local"
    },
    "webclaw": {
      "command": ["webclaw-mcp"],
      "enabled": true,
      "timeout": 120000,
      "type": "local"
    }
  },
  "model": "opencode/mimo-v2.5-free",
  "permission": {
    "bash": {
      "*": "allow",
      "cat *": "allow",
      "git branch *": "allow",
      "git checkout *": "ask",
      "git clean *": "ask",
      "git commit *": "ask",
      "git diff *": "allow",
      "git log *": "allow",
      "git merge *": "ask",
      "git push *": "ask",
      "git rebase *": "ask",
      "git reset *": "ask",
      "git status *": "allow",
      "ls *": "allow",
      "npm *": "allow",
      "npm publish *": "ask",
      "npm run db:push*": "ask",
      "npm run db:reset*": "deny",
      "npx *": "allow",
      "rm *": "deny",
      "rm -rf *": "deny",
      "sudo *": "deny"
    },
    "doom_loop": "ask",
    "edit": "allow",
    "external_directory": "ask",
    "question": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "*.key": "deny",
      "*.pem": "deny",
      "*credentials*": "deny",
      "*password*": "deny",
      "*secret*": "deny",
      "*token*": "deny"
    }
  },
  "plugin": ["@tarquinen/opencode-dcp@latest", "openslimedit@latest"],
  "provider": {
    "proxypal": {
      "models": {
        "claude-opus-4.6": {
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          },
          "name": "Claude Opus 4 6"
        },
        "coder-model": {
          "limit": {
            "context": 262144,
            "output": 65536
          },
          "name": "Coder Model"
        },
        "glm-4.5": {
          "limit": {
            "context": 128000,
            "output": 16384
          },
          "name": "Glm 4 5"
        },
        "glm-4.5-air": {
          "limit": {
            "context": 128000,
            "output": 16384
