  "share": "manual",
  "small_model": "opencode/gpt-5-nano",
  "watcher": {
    "ignore": [
      "node_modules/**",
      ".git/**",
      "dist/**",
      "build/**",
      ".fallow/**",
      "*.log",
      ".DS_Store"
    ]
  }
}
